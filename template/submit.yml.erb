<%-

  cores_lookup = {
      "any" => {"general" => 64},
      "gpu" => {"general" => 64},
  }

  slurm_args = []

  # GPU type
  gpu = gpu.blank? ? 0 : gpu.to_i
  node_type = gpu > 0 ? "gpu" : "any"

  if gpu > 0
    slurm_args = %W[--gres gpu:l40s.#{gpu}g:1]
  end


  max_cores = cores_lookup[node_type][cluster]
  num_cores = cores.blank? ? 0 : cores.to_i
  if num_cores > max_cores
    num_cores = max_cores
  end

  memory = num_cores * (memory_multiplier.blank? ? 1024 : memory_multiplier.to_i)
  if memory > 261144
    memory = 261144 # Limit to slightly less than 256GB
  end
%>
---
batch_connect:
  template: "basic"
script:
  queue_name: "general"
  native:
    - "--cpus-per-task"
    - "<%= num_cores %>"
    - "--mem"
    - "<%= memory %>"
    - "--nodes"
    - "1"
  <%- slurm_args.each do |arg| %>
    - "<%= arg %>"
  <%- end %>
